# MongoDB connections used by AI modules
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGO_URI_MAIN_APP=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Gemini API key for LLM-powered services
GEMINI_API_KEY=your_google_gemini_api_key

# Optional tuning
REVIEW_CACHE_TTL_HOURS=24
